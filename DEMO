    // Buddy encouragement lines, grouped by moment in the mission rhythm.
    // getCompanionLine() fills in the child's name and the companion's
    // chosen name/nickname at random from the matching pool.
    const COMPANION_LINES = {
      greetingMorning: ["Good morning, {user}! {buddy} is ready for an adventure.", "Rise and shine, {user}! {buddy} saved you a seat on today's adventure."],
      greetingGeneral: ["Hi {user}! {buddy} missed you.", "Welcome back, {user}! {buddy} has been practicing too.", "{buddy} is so happy to see you, {user}!"],
      warmup: ["Let's take one calm breath before we start, {user}.", "{buddy} always likes to warm up first. Ready?", "Nice and easy, {user} — just one breath with {buddy}."],
      celebrate: ["{buddy} is doing a happy dance for you!", "You did it, {user}! {buddy} is so proud.", "That was excellent, {user}! {buddy} says great job."],
      challenge: ["Try saying this to a real person today, {user} — {buddy} believes in you!", "{buddy} thinks you're ready to use this in real life today."]
