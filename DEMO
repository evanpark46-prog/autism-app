    <div id="screen-landing" class="screen active">
      <div class="landing-wrap">

        <section class="landing-section landing-hero" data-reveal>
          <span class="landing-eyebrow">Built for neurodiverse learners</span>
          <h1>A calm, predictable way to practice real conversations.</h1>
          <p class="landing-sub">Conversat Builders breaks everyday social moments &mdash; saying hello, asking to play, handling a loud lunchroom &mdash; into small, structured steps a child can rehearse at their own pace.</p>
          <div class="landing-cta-row">
            <button class="btn-pill-primary" onclick="showScreen('role-select')">Begin the Pathway →</button>
            <button class="btn-pill-ghost" onclick="document.getElementById('landing-how').scrollIntoView({behavior:'smooth'})">See how it works</button>
          </div>
