    function handleLogIn() {
      const usernameInput = document.getElementById('auth-username-field').value.trim();
      if (!usernameInput) { alert("Please enter a username to start your learning path."); return; }

      const storageKey = `conversat_profile_${usernameInput.toLowerCase()}`;
      const savedData = localStorage.getItem(storageKey);

      if (savedData) {
        const saved = JSON.parse(savedData);
        userState = Object.assign(getDefaultUserState(usernameInput), saved);
        // Backfill in case this profile predates a newer feature
        userState.aiSettings = userState.aiSettings || { enabled: false, apiKey: '', model: 'gpt-4o-mini' };
        userState.music = userState.music || { dataUrl: null, name: null, useInBreaks: false };
        userState.companionName = userState.companionName || getCompanionByEmoji(userState.avatar).name;
        if (typeof userState.totalStars !== 'number') userState.totalStars = Object.keys(userState.levelsCompleted || {}).length;
      } else {
        userState = getDefaultUserState(usernameInput);
        userState.avatar = selectedAvatar;
        userState.companionName = selectedCompanionName;
      }

      const todayString = new Date().toLocaleDateString();
      if (userState.lastActiveDay !== todayString) {
        const lastDate = new Date(userState.lastActiveDay);
        const diffTime = Math.abs(new Date() - lastDate);
        const diffDays = Math.ceil(diffTime / (1000 * 60 * 60 * 24));
        if (diffDays === 1) userState.streak += 1;
        else if (diffDays > 1) userState.streak = 1;
        userState.lastActiveDay = todayString;
      }

      saveProfileToStorage();
      isTherapistSession = false;
      enableAppSession();
    }

    function handleLogOut() {
      saveProfileToStorage();
      clearInterval(activeSessionTimer);
      stopBreakAudioIfPlaying();
      document.getElementById('app-nav').style.display = 'none';
      document.getElementById('logged-user-bar').style.display = 'none';
