    .option-btn.correct { border-color: #22c55e; background-color: #f0fdf4; color: #14532d; }
    .option-btn.incorrect { border-color: #ef4444; background-color: #fef2f2; color: #7f1d1d; }

    .calm-zone-card { background: var(--card-bg); border-radius: 24px; padding: 30px; box-shadow: var(--shadow-soft); text-align: center; display: flex; flex-direction: column; align-items: center; gap: 15px; }

    .breathing-buddy-circle {
      width: 150px; height: 150px; border-radius: 50%;
      background: linear-gradient(135deg, color-mix(in srgb, var(--primary) 60%, white), color-mix(in srgb, var(--primary) 30%, #c084fc));
      display: flex; align-items: center; justify-content: center; color: white; font-weight: 800; font-size: 1rem;
      transition: transform 4s ease-in-out;
      box-shadow: 0 0 20px color-mix(in srgb, var(--primary) 30%, transparent);
    }
    .breathing-buddy-circle.inhale { transform: scale(1.4); }
    .breathing-buddy-circle.exhale { transform: scale(0.9); }

    .modal-overlay {
      position: fixed; top: 0; left: 0; right: 0; bottom: 0; background: rgba(15, 23, 42, 0.45);
      z-index: 1000; display: flex; align-items: center; justify-content: center; padding: 20px;
      opacity: 0; pointer-events: none; transition: opacity 0.3s ease;
    }
    .modal-overlay.open { opacity: 1; pointer-events: auto; }
    .modal-content { background: var(--card-bg); border-radius: 24px; padding: 25px; max-width: 420px; width: 100%; text-align: center; box-shadow: 0 20px 25px -5px rgba(0, 0, 0, 0.1); }

    .founder-card { background-color: var(--card-bg); border-radius: 24px; padding: 30px 20px; box-shadow: var(--shadow-soft); text-align: center; display: flex; flex-direction: column; align-items: center; }
    .stanford-badge { background-color: var(--stanford-light); color: var(--stanford-cardinal); font-weight: 800; font-size: 0.75rem; padding: 6px 14px; border-radius: 20px; text-transform: uppercase; letter-spacing: 1px; margin-bottom: 12px; border: 1px solid #fed7d7; }
    .founder-avatar { width: 80px; height: 80px; background: linear-gradient(135deg, var(--stanford-cardinal), #c53030); border-radius: 50%; display: flex; align-items: center; justify-content: center; color: #ffffff; font-size: 1.8rem; font-weight: 800; margin-bottom: 15px; }
    .accessibility-toggle { background: none; border: 1px solid var(--text-muted); padding: 5px 10px; font-size: 0.75rem; border-radius: 8px; cursor: pointer; margin-top: 10px; color: var(--text-muted); font-family: var(--font-body); }

    /* ============================================================
       SETTINGS SCREEN
       ============================================================ */
    .settings-section { background: var(--card-bg); border-radius: 20px; padding: 20px; box-shadow: var(--shadow-soft); margin-bottom: 16px; }
    .settings-section h3 { margin: 0 0 4px 0; font-size: 1rem; }
    .settings-section .ss-desc { margin: 0 0 16px 0; font-size: 0.82rem; color: var(--text-muted); line-height: 1.4; }

    .preset-row { display: flex; gap: 8px; flex-wrap: wrap; margin-bottom: 16px; }
    .preset-chip { border: 2px solid var(--border-color); background: var(--card-bg); border-radius: 20px; padding: 7px 14px; font-size: 0.8rem; font-weight: 700; cursor: pointer; font-family: var(--font-body); display:flex; align-items:center; gap:6px; }
    .preset-chip.active { border-color: var(--primary); color: var(--primary); }
    .preset-swatch { width: 12px; height: 12px; border-radius: 50%; display: inline-block; }

    .color-input-row { display: flex; align-items: center; justify-content: space-between; padding: 8px 0; border-bottom: 1px solid var(--border-color); }
    .color-input-row:last-child { border-bottom: none; }
    .color-input-row label { font-size: 0.85rem; font-weight: 600; }
    .color-input-row input[type="color"] { width: 42px; height: 32px; border: none; border-radius: 8px; cursor: pointer; background: none; }

    .font-option-grid { display: flex; flex-direction: column; gap: 8px; }
    .font-option-card { border: 2px solid var(--border-color); border-radius: 12px; padding: 10px 14px; cursor: pointer; display: flex; justify-content: space-between; align-items: center; }
    .font-option-card.selected { border-color: var(--primary); background: var(--primary-light); }
    .font-option-card span.fo-sample { font-size: 1.1rem; }

    .toggle-row { display: flex; justify-content: space-between; align-items: center; padding: 10px 0; }
    .toggle-row label { font-size: 0.88rem; font-weight: 600; flex: 1; padding-right: 10px; }
    .switch { position: relative; display: inline-block; width: 46px; height: 26px; flex-shrink: 0; }
    .switch input { opacity: 0; width: 0; height: 0; }
    .switch-slider { position: absolute; cursor: pointer; top: 0; left: 0; right: 0; bottom: 0; background-color: #cbd5e0; transition: 0.3s; border-radius: 26px; }
    .switch-slider:before { position: absolute; content: ""; height: 20px; width: 20px; left: 3px; bottom: 3px; background-color: white; transition: 0.3s; border-radius: 50%; }
    .switch input:checked + .switch-slider { background-color: var(--primary); }
    .switch input:checked + .switch-slider:before { transform: translateX(20px); }

    .api-key-row { display: flex; gap: 8px; }
    .api-key-row input { flex: 1; }
    .key-eye-btn { background: var(--card-bg); border: 2px solid var(--border-color); border-radius: 10px; padding: 0 12px; cursor: pointer; font-size: 0.9rem; }
    .settings-note { font-size: 0.78rem; color: var(--text-muted); line-height: 1.4; margin-top: 8px; }
    .settings-note a { color: var(--primary); }
    .status-pill { display:inline-block; font-size: 0.78rem; font-weight: 700; padding: 4px 10px; border-radius: 10px; margin-top: 8px; }
    .status-pill.ok { background: #f0fdf4; color: #166534; }
    .status-pill.err { background: #fef2f2; color: #7f1d1d; }
    .status-pill.pending { background: #fffbeb; color: #92400e; }

    .music-drop {
      border: 2px dashed var(--border-color); border-radius: 14px; padding: 16px; text-align: center; cursor: pointer;
      font-size: 0.85rem; color: var(--text-muted); background: color-mix(in srgb, var(--card-bg), var(--text-main) 3%);
    }
    .music-now-playing { display:flex; align-items:center; justify-content: space-between; background: var(--primary-light); border-radius: 12px; padding: 10px 14px; margin-top: 10px; font-size: 0.85rem; font-weight: 600; }
    .music-now-playing button { background: none; border: none; color: #b91c1c; font-weight: 700; cursor: pointer; }
    .danger-btn { background: #fef2f2; color: #b91c1c; border: 1px solid #fecaca; border-radius: 12px; padding: 10px; font-weight: 700; cursor: pointer; width: 100%; font-family: var(--font-body); }

    .ai-badge-dynamic {
      display: inline-flex; align-items:center; gap:6px; font-size: 0.75rem; padding: 4px 10px; border-radius: 8px; width: fit-content; font-weight: 800;
    }
