    <nav id="app-nav" style="display: none;">
      <button class="nav-btn active" id="nav-home-btn" onclick="navigateTo('home')">🏠 Home</button>
      <button class="nav-btn" id="nav-pathway-btn" onclick="navigateTo('pathway')">🗺️ Journey</button>
      <button class="nav-btn" id="nav-rewards-btn" onclick="navigateTo('rewards')">🏆 Rewards</button>
      <button class="nav-btn" id="nav-buddy-btn" onclick="navigateTo('buddy')">🧸 My Buddy</button>
