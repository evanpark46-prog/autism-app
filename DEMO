    async function testAIKey() {
      onAISettingsChange();
      const statusEl = document.getElementById('ai-test-status');
      if (!userState.aiSettings.apiKey) {
        statusEl.innerHTML = '<span class="status-pill err">Enter an API key first</span>';
        return;
      }
      statusEl.innerHTML = '<span class="status-pill pending">Testing…</span>';
      try {
        await getAIGeneratedQuestion(DATA[0]);
        statusEl.innerHTML = '<span class="status-pill ok">✓ Key works — AI questions are ready</span>';
      } catch (err) {
        statusEl.innerHTML = `<span class="status-pill err">✗ ${err.message}</span>`;
      }
    }

    async function getAIGeneratedQuestion(lesson) {
      const phraseList = lesson.phrases.map(p => p.text).join('; ');
      const userPrompt = `Lesson topic: ${lesson.lessonTitle}. Skill being taught: ${lesson.description}. Target phrases the child is learning: ${phraseList}. Write ONE new multiple-choice scenario question that tests whether the child recognizes the right way to use this skill. Use a different made-up name and school location than last time.`;

      const response = await fetch('https://api.openai.com/v1/chat/completions', {
        method: 'POST',
        headers: {
          'Content-Type': 'application/json',
          'Authorization': `Bearer ${userState.aiSettings.apiKey}`
        },
        body: JSON.stringify({
          model: userState.aiSettings.model || 'gpt-4o-mini',
          messages: [
            { role: 'system', content: AI_SYSTEM_PROMPT },
            { role: 'user', content: userPrompt }
          ],
          temperature: 0.9,
          max_tokens: 300
        })
      });

      if (!response.ok) {
        if (response.status === 401) throw new Error('Invalid API key (401)');
        throw new Error(`OpenAI request failed (${response.status})`);
      }

      const data = await response.json();
      const raw = data.choices && data.choices[0] && data.choices[0].message && data.choices[0].message.content;
      if (!raw) throw new Error('Empty response from model');

      const cleaned = raw.trim().replace(/^```json\s*/i, '').replace(/```$/, '').trim();
      let parsed;
      try { parsed = JSON.parse(cleaned); } catch (e) { throw new Error('Model did not return valid JSON'); }

      if (!parsed.q || !Array.isArray(parsed.options) || parsed.options.length < 2 || !parsed.options.includes(parsed.a)) {
        throw new Error('Model response was missing required fields');
      }
      return { q: parsed.q, options: parsed.options, a: parsed.a };
    }

    function updateAIBadge(usedAI, fallbackMessage) {
      const badge = document.getElementById('quiz-ai-badge');
      const note = document.getElementById('ai-fallback-note');
      if (usedAI) {
        badge.className = 'ai-badge-dynamic on';
        badge.textContent = '🤖 AI Question Generator Active (ChatGPT)';
        note.style.display = 'none';
      } else {
        badge.className = 'ai-badge-dynamic off';
        badge.textContent = '🧩 Local Question Generator';
        if (fallbackMessage) { note.style.display = 'block'; note.textContent = fallbackMessage; }
        else { note.style.display = 'none'; }
      }
    }

    // ============================================================
    // LOCAL ("offline") PROCEDURAL QUESTION GENERATOR -- always
    // available as a fallback even if AI is off or a request fails.
    // ============================================================
    function generateLocalQuestionForLesson(lessonId) {
      const names = ["Leo", "Emma", "Noah", "Olivia", "Ethan", "Ava", "Lucas", "Mia", "Maya", "Liam", "Sophia", "Chloe"];
      const peerName = names[Math.floor(Math.random() * names.length)];
      const schoolArea = ["playground", "lunchroom", "classroom table", "reading rug", "library corridor", "art corner", "music room", "gym"];
      const location = schoolArea[Math.floor(Math.random() * schoolArea.length)];

      switch (lessonId) {
        case 'hello-names':
          return {
            q: `You meet ${peerName} on the ${location} for the first time. What is the friendliest way to begin talking?`,
            options: [
              `Wave friendly and say, "Hi! My name is ${userState.username || "Sam"}. What is your name?"`,
              `Ask them to hand you their juice box.`,
              `Stare quietly and do not say anything.`
            ],
            a: `Wave friendly and say, "Hi! My name is ${userState.username || "Sam"}. What is your name?"`
          };
        case 'asking-to-play':
          return {
            q: `${peerName} is using some cool building blocks on the floor. You would love to build too. What should you ask?`,
            options: [
              `Politely say, "Can I play with you?" and wait for their response.`,
              `Wait until they look away, then take some blocks.`,
              `Tell them blocks are boring and play something else.`
            ],
            a: `Politely say, "Can I play with you?" and wait for their response.`
          };
        case 'asking-help':
          return {
            q: `Your classroom work paper feels very hard to understand today, and you are stuck. What is a helpful action?`,
            options: [
              `Raise your hand and say, "I need help, please."`,
              `Crumple the paper up and hide it in your backpack.`,
              `Tap your neighbor's shoulder repeatedly while they write.`
            ],
            a: `Raise your hand and say, "I need help, please."`
          };
        case 'sharing-feelings':
          return {
            q: `The school ${location} is getting very loud, and you feel worried and need space. How can you tell your teacher?`,
            options: [
              `Say, "I need a quiet spot, please," so they can help you locate a calm area.`,
              `Leave the room immediately without saying anything.`,
              `Yell loudly so everyone knows it is too loud.`
            ],
            a: `Say, "I need a quiet spot, please," so they can help you locate a calm area.`
          };
        case 'table-manners':
          return {
            q: `You need the water pitcher, but it is sitting all the way on the other side of ${peerName}'s plate. What do you do?`,
            options: [
              `Politely ask, "Can you pass the water, please?"`,
              `Reach your arm across their food to grab it.`,
              `Pout until someone guesses what you need.`
            ],
            a: `Politely ask, "Can you pass the water, please?"`
          };
        case 'join-circle':
          return {
            q: `The class is sitting in a circle for a story. You find a neat spot next to ${peerName}. What is a good way to ask to sit down?`,
            options: [
              `Say kindly, "Is it okay if I sit here?"`,
              `Squeeze into the space without asking.`,
              `Tell ${peerName} to move over so you have more room.`
            ],
            a: `Say kindly, "Is it okay if I sit here?"`
          };
        case 'unexpected-transitions':
          return {
            q: `Your teacher says recess is indoors today due to sudden rain. How can you soothe your mind about this schedule change?`,
            options: [
              `Take a slow breath and say, "I can try something new."`,
              `Refuse to sit down and ask for outdoor play.`,
              `Put your head down and stay upset for the rest of the day.`
            ],
            a: `Take a slow breath and say, "I can try something new."`
          };
        case 'coping-mistakes':
          return {
            q: `You accidentally colored outside the lines on your fresh paper sheet. What is a healthy path forward?`,
            options: [
              `Remind yourself: "It is okay to make mistakes," and continue doing your best.`,
              `Tear up the paper and start crying.`,
              `Scribble over the whole page so no one can see your drawing.`
            ],
            a: `Remind yourself: "It is okay to make mistakes," and continue doing your best.`
          };
        case 'giving-compliment':
          return {
            q: `${peerName} just drew a beautiful spaceship picture during Art hour. How can you share kindness?`,
            options: [
              `Smile and say, "I like your drawing!"`,
              `Tell them your spaceship drawing is much bigger.`,
              `Look at it and turn away without saying anything.`
            ],
            a: `Smile and say, "I like your drawing!"`
          };
        default:
          return {
            q: "What is a helpful way to treat classmates?",
            options: ["Be friendly and wait your turn.", "Shout out instructions.", "Ignore them."],
            a: "Be friendly and wait your turn."
          };
      }
    }

    async function buildOneQuizQuestion(lesson) {
      if (userState.aiSettings.enabled && userState.aiSettings.apiKey) {
        try {
          const q = await getAIGeneratedQuestion(lesson);
          updateAIBadge(true);
          return q;
        } catch (err) {
          updateAIBadge(false, `AI question unavailable (${err.message}) — used a local question instead.`);
          return generateLocalQuestionForLesson(lesson.id);
        }
      }
      updateAIBadge(false);
      return generateLocalQuestionForLesson(lesson.id);
    }

