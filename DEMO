<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Conversat Builders - Sensory Friendly Learning</title>

  <!-- ============================================================
       CUSTOMIZE: FONTS
       Lexend was designed by a reading-proficiency lab to make text
       easier to decode -- a deliberate, on-brief pick for a literacy
       app. Baloo 2 is a warm, rounded display face for headings.
       Swap these two families if you want a different feel; just
       make sure to update FONT_PAIRS in the script below to match.
       ============================================================ -->
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Baloo+2:wght@500;600;700;800&family=Lexend:wght@400;500;600;700&display=swap" rel="stylesheet">

  <!-- Chart.js CDN for Progress Analytics -->
  <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

  <style>
    /* ============================================================
       CUSTOMIZE: COLOR THEME
       These four variables are the ONLY ones a learner ever needs to
       touch -- everything else (muted text, borders, light tints) is
       derived automatically with color-mix() so the whole app stays
       harmonious no matter what they pick in Settings.
       Edit the *defaults* here, or add more presets in THEME_PRESETS
       in the JS section below.
       ============================================================ */
    :root {
      --bg-color: #eef3f9;
      --card-bg: #ffffff;
      --primary: #3b82f6;
      --text-main: #1f2937;

      /* Derived tokens -- do not hand-edit, they recompute from the 4 above */
      --text-muted: color-mix(in srgb, var(--text-main) 55%, white);
      --border-color: color-mix(in srgb, var(--card-bg), var(--text-main) 14%);
      --primary-light: color-mix(in srgb, var(--primary) 14%, white);
      --primary-hover-filter: brightness(0.92);
      --shadow-soft: 0 4px 20px rgba(148, 163, 184, 0.10);
      --shadow-hover: 0 10px 25px rgba(148, 163, 184, 0.16);

      /* CUSTOMIZE: FONT PAIR -- overridden live by the font picker in Settings */
      --font-display: 'Baloo 2', system-ui, sans-serif;
      --font-body: 'Lexend', system-ui, -apple-system, sans-serif;
      --letter-spacing-boost: 0;
      --line-height-boost: 1;

      /* Pastel level colors (unchanged by the theme picker on purpose --
         each lesson keeps its own identity color so levels stay visually
         distinct and easy to remember/locate) */
      --pastel-blue: #dbeafe;
      --pastel-green: #dcfce7;
      --pastel-orange: #ffedd5;
      --pastel-purple: #f3e8ff;
      --pastel-pink: #fce7f3;
      --pastel-teal: #ccfbf1;

      --stanford-cardinal: #8c1515;
      --stanford-light: #fdf2f2;

      /* Marketing-only palette for the landing page & therapist portal.
         CUSTOMIZE: change these if you want a different "brand" feel --
         they are intentionally separate from the in-app theme system
         above so the first impression stays consistent regardless of
         what a logged-in learner has personalized. */
      --m-ink: #1f2937;
      --m-mist: #eaf1f8;
      --m-teal: #2d7d6f;
      --m-teal-dark: #205a51;
      --m-coral: #f08c5b;
      --m-stone: #e7ecf4;
      --m-purple: #6f63c9;
      --m-purple-light: #efecfa;
    }

    * { box-sizing: border-box; }

    body {
      font-family: var(--font-body);
      background-color: var(--bg-color);
      color: var(--text-main);
      margin: 0;
      padding: 0;
      display: flex;
      flex-direction: column;
      align-items: center;
      min-height: 100vh;
      -webkit-font-smoothing: antialiased;
      letter-spacing: calc(var(--letter-spacing-boost) * 1px);
      line-height: calc(1.5 * var(--line-height-boost));
      transition: background-color 0.3s ease, color 0.3s ease;
    }

    h1, h2, h3 { font-family: var(--font-display); }

    /* Respect motion sensitivity -- important for a sensory-friendly app */
    @media (prefers-reduced-motion: reduce) {
      *, *::before, *::after {
        animation-duration: 0.001ms !important;
        animation-iteration-count: 1 !important;
        transition-duration: 0.001ms !important;
      }
    }

    /* Visible keyboard focus everywhere */
    a:focus-visible, button:focus-visible, input:focus-visible, select:focus-visible {
      outline: 3px solid var(--primary);
      outline-offset: 2px;
      border-radius: 4px;
    }

    /* Accessibility Support: High Contrast Mode (also selectable as a theme preset) */
    body.high-contrast {
      --bg-color: #ffffff;
      --card-bg: #ffffff;
      --text-main: #000000;
      --primary: #0000ee;
    }

    body.extra-spacing { --letter-spacing-boost: 0.6; --line-height-boost: 1.18; }

    /* ============================================================
       LANDING PAGE (intro / marketing scroll page)
       Signature element: a "stepping path" that runs through the
       page -- a literal callback to the product's own "Pathway"
       metaphor (Listen -> Say it -> Master it), rather than a
       decorative generic numbered list.
       ============================================================ */
    .landing-wrap {
      width: 100%;
      background: linear-gradient(180deg, var(--m-mist) 0%, #ffffff 60%);
      color: var(--m-ink);
      font-family: var(--font-body);
    }

    .landing-section {
      width: 100%;
      max-width: 720px;
      margin: 0 auto;
      padding: 70px 24px;
      box-sizing: border-box;
      opacity: 0;
      transform: translateY(18px);
      transition: opacity 0.6s ease, transform 0.6s ease;
    }
    .landing-section.is-visible { opacity: 1; transform: translateY(0); }
    @media (prefers-reduced-motion: reduce) {
      .landing-section { opacity: 1; transform: none; }
    }

    .landing-hero {
      text-align: center;
      padding-top: 56px;
      position: relative;
    }

    .landing-eyebrow {
      display: inline-block;
      background: var(--m-stone);
      color: var(--m-teal-dark);
      font-weight: 700;
      font-size: 0.78rem;
      letter-spacing: 0.06em;
      text-transform: uppercase;
      padding: 6px 14px;
      border-radius: 20px;
      margin-bottom: 18px;
    }

    .landing-hero h1 {
      font-size: clamp(2rem, 6vw, 2.7rem);
      font-weight: 800;
      line-height: 1.15;
      margin: 0 0 14px 0;
      color: var(--m-ink);
    }

    .landing-hero .landing-sub {
      font-size: 1.05rem;
      color: color-mix(in srgb, var(--m-ink) 65%, white);
      max-width: 480px;
      margin: 0 auto 30px auto;
      line-height: 1.5;
    }

    .landing-cta-row { display: flex; gap: 12px; justify-content: center; flex-wrap: wrap; }

    .btn-pill-primary {
      background: var(--m-teal);
      color: white;
      border: none;
      font-family: var(--font-display);
      font-weight: 700;
      padding: 14px 26px;
      border-radius: 30px;
      font-size: 1rem;
      cursor: pointer;
      box-shadow: 0 8px 20px rgba(45, 125, 111, 0.25);
      transition: transform 0.15s ease;
    }
    .btn-pill-primary:hover { transform: translateY(-2px); }

    .btn-pill-ghost {
      background: transparent;
      color: var(--m-teal-dark);
      border: 2px solid var(--m-teal);
      font-family: var(--font-display);
      font-weight: 700;
      padding: 12px 24px;
      border-radius: 30px;
      font-size: 1rem;
      cursor: pointer;
    }

    /* Stepping-path SVG that visually threads the page together */
    .path-stones {
      display: flex;
      justify-content: center;
      align-items: center;
      gap: 6px;
      margin: 38px 0 10px 0;
    }
    .path-stone {
      width: 14px; height: 14px; border-radius: 50%;
      background: var(--m-teal);
      opacity: 0.35;
    }
    .path-stone:nth-child(2) { opacity: 0.6; transform: translateY(-6px); }
    .path-stone:nth-child(3) { opacity: 1; transform: translateY(-10px); width: 18px; height: 18px;}
    .path-stone:nth-child(4) { opacity: 0.6; transform: translateY(-6px); }
    .path-stone:nth-child(5) { opacity: 0.35; }
    .path-line { flex: 0 0 28px; height: 2px; background: color-mix(in srgb, var(--m-teal) 35%, transparent); }

    /* Mock "screenshot" cards -- illustrative recreations of real in-app
       screens, built in CSS so the landing page never depends on external
       images or stock photography. */
    .mock-frame {
      background: var(--card-bg, white);
      border-radius: 18px;
      box-shadow: var(--shadow-hover);
      padding: 16px;
      width: 100%;
      max-width: 290px;
      margin: 0 auto;
      border: 1px solid var(--m-stone);
    }
    .mock-frame .mock-dot-row { display:flex; gap:5px; margin-bottom:10px; }
    .mock-frame .mock-dot { width:8px; height:8px; border-radius:50%; background: var(--m-stone); }

    .feature-stone-grid {
      display: grid;
      grid-template-columns: 1fr;
      gap: 22px;
    }
    .feature-stone {
      background: white;
      border-radius: 20px;
      padding: 22px;
      box-shadow: var(--shadow-soft);
      display: flex;
      gap: 16px;
      align-items: flex-start;
      border: 1px solid var(--m-stone);
    }
    .feature-stone .fs-icon {
      flex-shrink: 0;
      width: 46px; height: 46px;
      border-radius: 14px;
      display: flex; align-items: center; justify-content: center;
      font-size: 1.3rem;
    }
    .feature-stone h3 { margin: 0 0 6px 0; font-size: 1.05rem; }
    .feature-stone p { margin: 0; font-size: 0.92rem; color: color-mix(in srgb, var(--m-ink) 60%, white); line-height: 1.45; }

    .landing-quote {
      background: var(--m-stone);
      border-radius: 24px;
      padding: 34px 28px;
      text-align: center;
    }
    .landing-quote p.quote-text {
      font-size: 1.15rem;
      font-weight: 600;
      font-family: var(--font-display);
      color: var(--m-teal-dark);
      line-height: 1.45;
      margin: 0 0 10px 0;
    }
    .landing-quote .quote-attr { font-size: 0.85rem; color: color-mix(in srgb, var(--m-ink) 60%, white); }

    .landing-founder-strip {
      display: flex; align-items: center; gap: 14px;
      background: var(--stanford-light);
      border: 1px solid #fed7d7;
      border-radius: 20px;
      padding: 16px 18px;
    }
    .landing-founder-strip .lf-avatar {
      width: 48px; height: 48px; border-radius: 50%;
      background: linear-gradient(135deg, var(--stanford-cardinal), #c53030);
      color: white; display:flex; align-items:center; justify-content:center;
      font-weight: 800; flex-shrink: 0;
    }
    .landing-founder-strip p { margin: 0; font-size: 0.88rem; color: var(--m-ink); line-height: 1.4; }

    .landing-final-cta { text-align: center; padding-bottom: 90px; }

    /* ============================================================
       ROLE SELECTION
       ============================================================ */
    .role-select-wrap { max-width: 560px; margin: 0 auto; padding: 60px 20px 90px; text-align:center; }
    .role-grid { display: grid; grid-template-columns: 1fr; gap: 18px; margin-top: 30px; }
    @media (min-width: 480px) { .role-grid { grid-template-columns: 1fr 1fr; } }

    .role-card {
      background: white;
      border-radius: 22px;
      padding: 28px 20px;
      box-shadow: var(--shadow-soft);
      cursor: pointer;
      border: 2px solid transparent;
      transition: border-color 0.2s, transform 0.2s;
      text-align: left;
    }
    .role-card:hover { transform: translateY(-3px); }
    .role-card.role-student { border-color: var(--m-teal); }
    .role-card.role-therapist { border-color: var(--m-purple); }
    .role-card .rc-emoji { font-size: 2.2rem; margin-bottom: 10px; display:block; }
    .role-card h3 { margin: 0 0 6px 0; font-size: 1.15rem; }
    .role-card p { margin: 0; font-size: 0.85rem; color: var(--text-muted); line-height: 1.4; }
    .role-card.role-student h3 { color: var(--m-teal-dark); }
    .role-card.role-therapist h3 { color: var(--m-purple); }

    /* Header Styling */
    header {
      background-color: #ffffff;
      width: 100%;
      box-shadow: 0 2px 8px rgba(0, 0, 0, 0.03);
      display: flex;
      flex-direction: column;
      align-items: center;
      padding: 20px 15px 15px 15px;
      box-sizing: border-box;
      position: sticky;
      top: 0;
      z-index: 100;
    }

    header h1 {
      margin: 0;
      font-size: 1.8rem;
      font-weight: 800;
      letter-spacing: -0.5px;
      color: var(--primary);
      cursor: pointer;
    }

    header p {
      margin: 4px 0 12px 0;
      font-size: 0.9rem;
      color: var(--text-muted);
      font-weight: 500;
    }

    .user-info-bar {
      display: flex;
      align-items: center;
      justify-content: space-between;
      width: 100%;
      max-width: 550px;
      padding: 8px 12px;
      margin: 8px 0;
      background: var(--primary-light);
      border-radius: 12px;
      font-size: 0.85rem;
      font-weight: 600;
      gap: 8px;
    }

    .user-info-bar button {
      background: none;
      border: 1px solid var(--primary);
      color: var(--primary);
      padding: 4px 10px;
      border-radius: 8px;
      cursor: pointer;
      font-size: 0.8rem;
      font-weight: 700;
      transition: all 0.2s;
    }

    .user-info-bar button:hover { background: var(--primary); color: white; }

    nav {
      display: flex;
      background-color: #f1f5f9;
      padding: 4px;
      border-radius: 30px;
      gap: 5px;
      margin-top: 5px;
      max-width: 100%;
      overflow-x: auto;
    }

    .nav-btn {
      background: none;
      border: none;
      padding: 8px 14px;
      border-radius: 20px;
      font-size: 0.82rem;
      font-weight: 700;
      color: var(--text-muted);
      cursor: pointer;
      transition: all 0.2s ease;
      display: flex;
      align-items: center;
      gap: 5px;
      white-space: nowrap;
      flex-shrink: 0;
    }

    .nav-btn.active {
      background-color: #ffffff;
      color: var(--primary);
      box-shadow: 0 2px 8px rgba(0, 0, 0, 0.05);
    }

    main {
      width: 100%;
      max-width: 550px;
      padding: 15px 15px 50px 15px;
      box-sizing: border-box;
    }

    .screen { display: none; }
    .screen.active { display: block; animation: fadeIn 0.25s ease-out; }

    @keyframes fadeIn {
      from { opacity: 0; transform: translateY(5px); }
      to { opacity: 1; transform: translateY(0); }
    }

    /* Auth Portal Form Design (Student) */
    .auth-card {
      background: var(--card-bg);
      border-radius: 24px;
      padding: 30px 24px;
      box-shadow: var(--shadow-soft);
      text-align: center;
    }

    .avatar-grid {
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      gap: 10px;
      margin: 14px 0 22px 0;
    }
    .avatar-option {
      font-size: 1.6rem;
      background: var(--bg-color);
      border: 2px solid transparent;
      border-radius: 14px;
      padding: 10px 0;
      cursor: pointer;
      transition: all 0.15s;
    }
    .avatar-option.selected { border-color: var(--primary); background: var(--primary-light); }

    .auth-input {
      width: 100%;
      padding: 12px 16px;
      margin: 10px 0 20px 0;
      border: 2px solid var(--border-color);
      border-radius: 12px;
      font-size: 1rem;
      font-family: var(--font-body);
      box-sizing: border-box;
      outline: none;
      transition: border-color 0.2s;
      background: var(--card-bg);
      color: var(--text-main);
    }

    .auth-input:focus { border-color: var(--primary); }

    .auth-switch-link {
      display: block;
      margin-top: 14px;
      font-size: 0.82rem;
      color: var(--text-muted);
      background: none;
      border: none;
      cursor: pointer;
      text-decoration: underline;
      font-family: var(--font-body);
    }

    /* Therapist portal (distinct professional palette via --m-purple, not the in-app theme system) */
    .therapist-shell { background: var(--m-purple-light); min-height: 100vh; width: 100%; }
    .therapist-topbar {
      background: white; padding: 16px 20px; display:flex; justify-content: space-between; align-items: center;
      box-shadow: 0 2px 8px rgba(0,0,0,0.04);
    }
    .therapist-topbar .tt-brand { font-family: var(--font-display); font-weight: 800; color: var(--m-purple); font-size: 1.2rem; }
    .therapist-card {
      max-width: 480px; margin: 50px auto; background: white; border-radius: 24px;
      padding: 32px 26px; box-shadow: var(--shadow-soft); text-align: center;
    }
    .therapist-card .tc-badge {
      background: var(--m-purple-light); color: var(--m-purple); font-weight: 800; font-size: 0.72rem;
      letter-spacing: 0.06em; text-transform: uppercase; padding: 6px 14px; border-radius: 20px; display:inline-block; margin-bottom: 14px;
    }
    .therapist-input {
      width: 100%; padding: 12px 16px; margin: 8px 0 16px 0; border: 2px solid #e3ddf5;
      border-radius: 12px; font-size: 0.95rem; font-family: var(--font-body); box-sizing: border-box;
    }
    .therapist-input:focus { outline: none; border-color: var(--m-purple); }
    .btn-purple {
      background: var(--m-purple); color: white; border:none; border-radius: 12px; padding: 13px;
      font-weight: 700; font-family: var(--font-display); width: 100%; cursor: pointer; font-size: 0.95rem;
    }
    .therapist-dash-wrap { max-width: 560px; margin: 0 auto; padding: 24px 18px 60px; }
    .student-row {
      background: white; border-radius: 16px; padding: 16px 18px; margin-bottom: 12px;
      box-shadow: var(--shadow-soft); display: flex; align-items: center; gap: 14px;
    }
    .student-row .sr-avatar { font-size: 1.7rem; background: var(--m-purple-light); border-radius: 50%; width: 46px; height: 46px; display:flex; align-items:center; justify-content:center; flex-shrink:0; }
    .student-row .sr-meta { flex-grow: 1; }
    .student-row .sr-meta strong { display:block; font-size: 1rem; }
    .student-row .sr-meta span { font-size: 0.8rem; color: var(--text-muted); }
    .student-row .sr-progress-pill {
      background: var(--m-purple-light); color: var(--m-purple); font-weight: 700; font-size: 0.78rem;
      padding: 5px 10px; border-radius: 12px; white-space: nowrap;
    }
    .therapist-empty-note { text-align: center; color: var(--text-muted); font-size: 0.9rem; padding: 40px 20px; }
    .therapist-disclaimer {
      background: #fff7ed; border: 1px solid #fed7aa; color: #92400e; font-size: 0.78rem;
      border-radius: 12px; padding: 10px 14px; margin: 0 0 18px 0; line-height: 1.4;
    }

    /* Level Cards */
    .level-card {
      background-color: var(--card-bg);
      border-radius: 20px;
      padding: 20px;
      margin-bottom: 15px;
      box-shadow: var(--shadow-soft);
      transition: transform 0.2s ease, box-shadow 0.2s ease;
      box-sizing: border-box;
      display: flex;
      flex-direction: column;
      gap: 12px;
    }

    .level-card:hover { transform: translateY(-2px); box-shadow: var(--shadow-hover); }

    .level-header-area { display: flex; align-items: center; gap: 15px; }

    .level-illustration {
      width: 55px; height: 55px; border-radius: 12px; flex-shrink: 0;
      display: flex; align-items: center; justify-content: center;
    }

    .level-text-block { flex-grow: 1; }
    .level-title { margin: 0 0 4px 0; font-size: 1.1rem; font-weight: 800; }
    .level-desc { margin: 0; font-size: 0.85rem; color: var(--text-muted); line-height: 1.4; }

    .lesson-btn {
      display: flex; justify-content: space-between; align-items: center; width: 100%;
      padding: 12px 18px; background-color: var(--card-bg); border: 2px solid var(--border-color);
      border-radius: 12px; cursor: pointer; font-size: 0.9rem; font-weight: 700;
      color: var(--text-main); transition: all 0.2s ease; text-align: left; font-family: var(--font-body);
    }
    .lesson-btn:hover { border-color: #cbd5e0; }
    .lesson-btn.completed { background-color: #f0fdf4; border-color: #bbf7d0; color: #166534; }

    /* Dashboard & Graphing */
    .dashboard-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 12px; margin-bottom: 20px; }
    .metric-card { background: var(--card-bg); padding: 15px; border-radius: 16px; box-shadow: var(--shadow-soft); text-align: center; }
    .metric-val { font-size: 1.6rem; font-weight: 850; color: var(--primary); margin-top: 5px; }
    .metric-label { font-size: 0.75rem; font-weight: 700; color: var(--text-muted); text-transform: uppercase; }
    .chart-container { background: var(--card-bg); border-radius: 20px; padding: 15px; box-shadow: var(--shadow-soft); margin-bottom: 15px; }
    .chart-title { font-size: 0.9rem; font-weight: 800; margin-bottom: 12px; color: var(--text-main); text-transform: uppercase; letter-spacing: 0.5px; }

    /* Practice Core Screens */
    .card { background-color: var(--card-bg); border-radius: 24px; padding: 24px; box-shadow: var(--shadow-soft); display: flex; flex-direction: column; gap: 16px; }
    .progress-bar-bg { width: 100%; height: 8px; background-color: color-mix(in srgb, var(--card-bg), var(--text-main) 6%); border-radius: 5px; overflow: hidden; }
    .progress-bar-active { height: 100%; background: var(--primary); width: 0%; transition: width 0.4s ease; }
    .card-header { display: flex; justify-content: space-between; align-items: center; }
    .back-btn { background: none; border: none; color: var(--text-muted); cursor: pointer; font-size: 0.85rem; font-weight: 700; padding: 0; font-family: var(--font-body); }
    .step-text { font-size: 0.8rem; color: var(--text-muted); font-weight: 700; text-transform: uppercase; }

    .phrase-display { text-align: center; padding: 24px 15px; background: color-mix(in srgb, var(--card-bg), var(--text-main) 3%); border-radius: 16px; border: 1px solid var(--border-color); }
    .phrase-text { font-size: 1.4rem; margin: 0 0 15px 0; color: var(--text-main); line-height: 1.4; font-weight: 800; }

    .button-group { display: flex; justify-content: center; gap: 10px; flex-wrap: wrap; }
    .speak-btn { background-color: var(--card-bg); border: 1.5px solid var(--border-color); border-radius: 25px; padding: 10px 18px; font-size: 0.85rem; font-weight: 700; color: var(--text-main); cursor: pointer; font-family: var(--font-body); }
