    // ============================================================
    // BREATHING BUDDY (calm breathing animation + tone cue)
    // ============================================================
    let breathingBuddyInterval = null;
    function startBreathingAnimation(circleId, textId) {
      const circle = document.getElementById(circleId);
      const text = document.getElementById(textId);
      let step = 0;
      if (breathingBuddyInterval) clearInterval(breathingBuddyInterval);

      const cycle = () => {
        if (step === 0) { circle.className = circle.className.replace(/\binhale\b|\bexhale\b/g, '').trim() + " inhale"; text.textContent = "Breathe In"; playTone(220, 1.5); step = 1; }
        else if (step === 1) { text.textContent = "Hold Breath"; step = 2; }
        else { circle.className = circle.className.replace(/\binhale\b|\bexhale\b/g, '').trim() + " exhale"; text.textContent = "Breathe Out"; playTone(180, 1.5); step = 0; }
      };
      cycle();
      breathingBuddyInterval = setInterval(cycle, 4000);
    }
    function stopBreathingAnimation() { if (breathingBuddyInterval) clearInterval(breathingBuddyInterval); }

    function playTone(freq, duration) {
      if (!soundEnabled) return;
      try {
        if (!audioCtx) audioCtx = new (window.AudioContext || window.webkitAudioContext)();
        const osc = audioCtx.createOscillator();
        const gain = audioCtx.createGain();
        osc.connect(gain);
        gain.connect(audioCtx.destination);
        osc.type = 'sine';
        osc.frequency.setValueAtTime(freq, audioCtx.currentTime);
        gain.gain.setValueAtTime(0.06, audioCtx.currentTime);
        gain.gain.exponentialRampToValueAtTime(0.001, audioCtx.currentTime + duration);
        osc.start();
        osc.stop(audioCtx.currentTime + duration);
      } catch (err) { console.warn("Audio Context blocked or not supported on this device."); }
    }

    function toggleBreathingTone() {
      soundEnabled = !soundEnabled;
      document.getElementById('breathing-sound-btn').textContent = soundEnabled ? "🔊 Sound: ON" : "🔇 Sound: OFF";
    }

