    .ai-badge-dynamic.off { background-color: var(--pastel-blue); color: var(--primary); }
    .ai-fallback-note { font-size: 0.75rem; color: #92400e; background: #fffbeb; padding: 6px 10px; border-radius: 8px; }
  </style>
