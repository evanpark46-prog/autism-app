          <div class="mock-frame">
            <div class="mock-dot-row"><div class="mock-dot"></div><div class="mock-dot"></div><div class="mock-dot"></div></div>
            <div style="text-align:center; padding: 10px 0;">
              <div style="font-size:0.7rem; font-weight:800; color:#1d4ed8; text-transform:uppercase; letter-spacing:0.05em; margin-bottom:8px;">🗣️ Step 2: Your Turn to Speak</div>
              <div style="font-weight:800; font-size:1.05rem; margin-bottom:10px;">"Can I play with you?"</div>
