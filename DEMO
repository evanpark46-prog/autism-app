      if (isListening) { recognition.stop(); }
      else { try { recognition.start(); } catch (e) { console.error(e); } }
    }

    function verifySpokenPhrase(spokenText) {
      const targetPhrase = DATA[currentLessonIdx].phrases[currentPhraseIdx].text;
      const cleanTarget = targetPhrase.toLowerCase().replace(/[.,\/#!$%\^&\*;:{}=\-_`~()?]/g,"").trim();
      const cleanSpoken = spokenText.toLowerCase().replace(/[.,\/#!$%\^&\*;:{}=\-_`~()?]/g,"").trim();

      if (cleanSpoken === cleanTarget || cleanSpoken.includes(cleanTarget) || cleanTarget.includes(cleanSpoken)) {
        document.getElementById('spoken-text-feedback').textContent = "✨ Great job! Sounded perfect.";
        document.getElementById('lesson-primary-btn').disabled = false;
        document.getElementById('lesson-primary-btn').textContent = "Next Step →";
      } else {
        document.getElementById('spoken-text-feedback').textContent = `Keep trying! (Or click "I said it!" to bypass)`;
      }
    }

