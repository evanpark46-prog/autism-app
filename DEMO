    function loadPhraseStep() {
      const lesson = DATA[currentLessonIdx];
      const phrase = lesson.phrases[currentPhraseIdx];

      document.getElementById('phrase-text').textContent = `"${phrase.text}"`;
      document.getElementById('context-text').textContent = phrase.context;
      document.getElementById('step-indicator').textContent = `Learning Step ${currentPhraseIdx + 1} of ${lesson.phrases.length}`;
      document.getElementById('spoken-text-feedback').textContent = "";
      resetHintUI();

      const progressPercent = ((currentPhraseIdx + 0.5) / (lesson.phrases.length + 1)) * 100;
      document.getElementById('lesson-progress').style.width = progressPercent + '%';

      if (currentPhase === 'read') {
        document.getElementById('practice-instruction').innerHTML = "👀 STEP 1: READ & LISTEN";
        document.getElementById('mic-btn').style.display = 'none';
        document.getElementById('skip-speech-btn').style.display = 'none';
        document.getElementById('lesson-primary-btn').disabled = false;
        document.getElementById('lesson-primary-btn').textContent = "Listen & Go to Verbal Practice →";
      } else {
        document.getElementById('practice-instruction').innerHTML = "🗣️ STEP 2: YOUR TURN TO SPEAK";
        document.getElementById('mic-btn').style.display = 'inline-block';
        document.getElementById('skip-speech-btn').style.display = 'block';
        document.getElementById('lesson-primary-btn').disabled = true;
        document.getElementById('lesson-primary-btn').textContent = "Speak to Unlock Next →";
      }
    }

    function handleNextStep() {
      const lesson = DATA[currentLessonIdx];
      if (currentPhase === 'read') {
        currentPhase = 'speak';
        loadPhraseStep();
      } else if (currentPhraseIdx < lesson.phrases.length - 1) {
        currentPhraseIdx++;
        currentPhase = 'read';
        loadPhraseStep();
      } else {
        startMasteryTest();
      }
    }

    // ============================================================
    // MASTERY QUIZ
    // ============================================================
    async function startMasteryTest() {
      masteryScore = 0;
      currentQuizIdx = 0;
      currentQuizPool = [];
      updateMasteryUI();
      showScreen('quiz');
      document.getElementById('quiz-question').textContent = 'Loading your next question…';
      document.getElementById('quiz-options').innerHTML = '';
      for (let i = 0; i < 4; i++) currentQuizPool.push(await buildOneQuizQuestion(DATA[currentLessonIdx]));
      loadNextQuizQuestion();
    }

    function updateMasteryUI() { document.getElementById('mastery-score-display').textContent = masteryScore; }

    async function loadNextQuizQuestion() {
      if (masteryScore >= 100) { showRealWorldChallenge(); return; }

      if (currentQuizIdx >= currentQuizPool.length) {
        currentQuizIdx = 0;
        currentQuizPool = [];
        document.getElementById('quiz-question').textContent = 'Loading your next question…';
        for (let i = 0; i < 4; i++) currentQuizPool.push(await buildOneQuizQuestion(DATA[currentLessonIdx]));
      }

      const activeQuestion = currentQuizPool[currentQuizIdx];
      document.getElementById('quiz-question').textContent = activeQuestion.q;

      const optionsContainer = document.getElementById('quiz-options');
      optionsContainer.innerHTML = '';
      selectedOption = null;

      document.getElementById('quiz-feedback').style.display = 'none';
      document.getElementById('quiz-check-btn').style.display = 'block';
      document.getElementById('quiz-check-btn').disabled = true;

      const choices = [...activeQuestion.options].sort(() => Math.random() - 0.5);
      choices.forEach((opt) => {
        const btn = document.createElement('button');
        btn.className = 'option-btn';
        btn.textContent = opt;
        btn.onclick = () => selectOption(btn, opt);
        optionsContainer.appendChild(btn);
      });
    }

    function selectOption(buttonElement, optionText) {
      document.querySelectorAll('.option-btn').forEach(btn => btn.classList.remove('selected'));
      buttonElement.classList.add('selected');
      selectedOption = optionText;
      document.getElementById('quiz-check-btn').disabled = false;
    }

    function checkAnswer() {
      const activeQuestion = currentQuizPool[currentQuizIdx];
      const isCorrect = selectedOption === activeQuestion.a;

      document.querySelectorAll('.option-btn').forEach(btn => {
        btn.disabled = true;
        if (btn.textContent === activeQuestion.a) btn.classList.add('correct');
        else if (btn.textContent === selectedOption) btn.classList.add('incorrect');
      });

      const feedbackMsg = document.getElementById('feedback-message');
      if (isCorrect) {
        masteryScore += 25;
        feedbackMsg.textContent = "🌟 Correct! That's very friendly and helpful. (+25 Points)";
        feedbackMsg.style.color = "#15803d";
        playTone(330, 0.2);
        setTimeout(() => playTone(440, 0.3), 150);
      } else {
        masteryScore = Math.max(0, masteryScore - 10);
        feedbackMsg.textContent = `Expected friendly path: "${activeQuestion.a}" (-10 Points)`;
        feedbackMsg.style.color = "#b91c1c";
        playTone(180, 0.4);
      }

      updateMasteryUI();
      document.getElementById('quiz-check-btn').style.display = 'none';
      document.getElementById('quiz-feedback').style.display = 'flex';
      currentQuizIdx++;
    }

    function showRealWorldChallenge() {
      const lesson = DATA[currentLessonIdx];
      const samplePhrase = lesson.phrases[0].text;
      document.getElementById('challenge-line').textContent = getCompanionLine('challenge');
      document.getElementById('challenge-phrase').textContent = `"${samplePhrase}"`;
      showScreen('challenge');
    }

    function finishLesson() {
      const lesson = DATA[currentLessonIdx];
      const alreadyEarned = !!userState.levelsCompleted[lesson.id];
      userState.levelsCompleted[lesson.id] = true;
      if (!alreadyEarned) userState.totalStars = (userState.totalStars || 0) + 1;
      saveProfileToStorage();

      document.getElementById('complete-title').textContent = "100 Mastery Score Achieved!";
      document.getElementById('complete-message').innerHTML = `${getCompanionLine('celebrate')}<br><br>You earned the <strong>${lesson.sticker}</strong> sticker for <strong>${lesson.lessonTitle}</strong>!`;

      showScreen('complete');
      updateDashboardUI();
    }

    // ============================================================
    // ANALYTICS & DASHBOARD GRAPHS (Chart.js)
    // ============================================================
    let timeChartRef = null;
    let progressChartRef = null;

    function updateDashboardUI() {
      document.getElementById('stats-minutes-played').textContent = `${Math.round(userState.totalMinutes)} min`;
      const finishedCount = Object.keys(userState.levelsCompleted).length;
      document.getElementById('stats-lessons-complete').textContent = `${finishedCount} / 9`;
      updateDashboardCharts(finishedCount);
    }

    function initDashboardCharts() {
      const ctxTime = document.getElementById('timeChart').getContext('2d');
      const primaryColor = getComputedStyle(document.documentElement).getPropertyValue('--primary').trim() || '#3b82f6';
      timeChartRef = new Chart(ctxTime, {
        type: 'bar',
        data: {
          labels: ['Mon', 'Tue', 'Wed', 'Thu', 'Fri', 'Sat', 'Sun'],
          datasets: [{ label: 'Minutes Spent', data: userState.weeklyData, backgroundColor: primaryColor, borderColor: primaryColor, borderWidth: 1, borderRadius: 6 }]
        },
        options: {
          responsive: true, maintainAspectRatio: false,
          plugins: { legend: { display: false } },
          scales: { y: { beginAtZero: true, grid: { color: '#f1f5f9' } }, x: { grid: { display: false } } }
        }
      });

      const ctxProgress = document.getElementById('progressChart').getContext('2d');
      progressChartRef = new Chart(ctxProgress, {
        type: 'doughnut',
        data: { labels: ['Completed', 'Remaining'], datasets: [{ data: [0, 9], backgroundColor: [primaryColor, '#e2e8f0'], borderWidth: 0 }] },
        options: { responsive: true, maintainAspectRatio: false, plugins: { legend: { position: 'bottom' } } }
      });
    }

    function updateDashboardCharts(completedCount) {
      if (timeChartRef) { timeChartRef.data.datasets[0].data = userState.weeklyData; timeChartRef.update(); }
      if (progressChartRef) { progressChartRef.data.datasets[0].data = [completedCount, 9 - completedCount]; progressChartRef.update(); }
    }

    // ============================================================
    // BOOT
    // ============================================================
    window.onload = function() {
      renderAvatarGrid();
      initLandingReveal();
      showScreen('landing');
    };
  </script>
</body>
</html>
